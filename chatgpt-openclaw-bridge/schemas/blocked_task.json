{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BlockedTaskPackage",
  "type": "object",
  "required": [
    "task_id",
    "project",
    "branch",
    "source_agent",
    "task_status",
    "goal",
    "acceptance_criteria",
    "current_problem",
    "first_error_time",
    "last_progress_time",
    "attempt_count",
    "attempted_solutions",
    "commands_executed",
    "error_logs",
    "stack_trace",
    "git_diff_summary",
    "changed_files",
    "environment",
    "agent_conclusion",
    "agent_confidence",
    "requested_help",
    "screenshots",
    "sensitive_data_removed"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "project": { "type": "string" },
    "branch": { "type": "string" },
    "source_agent": { "type": "string" },
    "task_status": { "type": "string" },
    "goal": { "type": "string" },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
    "current_problem": { "type": "string" },
    "first_error_time": { "type": "string" },
    "last_progress_time": { "type": "string" },
    "attempt_count": { "type": "integer", "minimum": 0 },
    "attempted_solutions": { "type": "array" },
    "commands_executed": { "type": "array", "minItems": 1 },
    "error_logs": { "type": "array" },
    "stack_trace": { "type": "array" },
    "git_diff_summary": { "type": "string" },
    "changed_files": { "type": "array" },
    "environment": {
      "type": "object",
      "required": ["os", "unity_version", "dotnet_version", "openclaw_version"]
    },
    "agent_conclusion": { "type": "string" },
    "agent_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "requested_help": { "type": "string" },
    "screenshots": { "type": "array" },
    "sensitive_data_removed": { "const": true }
  }
}

