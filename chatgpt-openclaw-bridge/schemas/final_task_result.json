{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FinalTaskResult",
  "type": "object",
  "required": [
    "result_id",
    "created_at",
    "task_id",
    "status",
    "summary",
    "evidence",
    "qa_result",
    "compile_passed",
    "tests_passed",
    "regression_passed",
    "severe_new_issue",
    "git_diff_reviewed",
    "evidence_archived",
    "skill_review_passed",
    "feishu_summary_sent",
    "caveats",
    "blockers",
    "next_actions",
    "sensitive_data_removed"
  ],
  "properties": {
    "result_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["PASS", "CONDITIONAL_PASS", "REWORK", "BLOCKED"] },
    "summary": { "type": "string", "minLength": 1 },
    "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "qa_result": { "type": "string", "minLength": 1 },
    "compile_passed": { "type": "boolean" },
    "tests_passed": { "type": "boolean" },
    "regression_passed": { "type": "boolean" },
    "severe_new_issue": { "type": "boolean" },
    "git_diff_reviewed": { "type": "boolean" },
    "evidence_archived": { "type": "boolean" },
    "skill_review_passed": { "type": "boolean" },
    "feishu_summary_sent": { "type": "boolean" },
    "caveats": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "blockers": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "next_actions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "sensitive_data_removed": { "const": true }
  },
  "additionalProperties": false
}
